<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CaddieAIAndroid" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash screen theme: system draws launcher icon centered on white during cold start.
         postSplashScreenTheme transitions to the main app theme after install. -->
    <style name="Theme.CaddieAIAndroid.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/black</item>
        <item name="postSplashScreenTheme">@style/Theme.CaddieAIAndroid</item>
    </style>

</resources>
