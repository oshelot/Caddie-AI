{
  "version": "1.0",
  "description": "Cross-platform design token mapping: iOS system defaults → Android Material overrides",
  "colors": {
    "primary": { "ios": "systemBlue (#007AFF)", "android": "SystemBlue (#1565C0)", "usage": "Links, active elements, primary actions" },
    "secondary": { "ios": "systemGreen (#34C759)", "android": "SuccessGreen (#2E7D32)", "usage": "Success states, caddie/low-risk" },
    "background": { "ios": "systemBackground (white/black)", "android": "SecondarySystemBackground (#F2F2F7)", "usage": "Screen background" },
    "surface": { "ios": "secondarySystemBackground (#F2F2F7)", "android": "SystemBackground (#FFFFFF)", "usage": "Card surfaces" },
    "surfaceVariant": { "ios": "systemGray6 (#E5E5EA)", "android": "SystemGray6 (#E5E5EA)", "usage": "Input fields, dividers" },
    "error": { "ios": "systemRed (#FF3B30)", "android": "ErrorRed (#B71C1C)", "usage": "Errors, high risk" },
    "tertiary": { "ios": "systemPurple (#AF52DE)", "android": "PremiumPurple (#6A1B9A)", "usage": "Pro/premium features" }
  },
  "typography": {
    "displayLarge": { "ios": "largeTitle (34pt bold)", "android": "36sp bold", "usage": "Club recommendation hero" },
    "displayMedium": { "ios": "largeTitle (34pt bold rounded)", "android": "34sp bold", "usage": "Splash logo" },
    "headlineLarge": { "ios": "title (28pt bold)", "android": "24sp bold", "usage": "Section headers" },
    "headlineMedium": { "ios": "headline (17pt semibold)", "android": "20sp semibold", "usage": "Section titles" },
    "titleLarge": { "ios": "title3 (20pt)", "android": "22sp semibold", "usage": "Card/screen titles" },
    "bodyLarge": { "ios": "body (17pt)", "android": "16sp regular", "usage": "Default readable content" },
    "bodyMedium": { "ios": "callout (16pt)", "android": "15sp regular", "usage": "Execution details" },
    "bodySmall": { "ios": "subheadline (15pt)", "android": "13sp regular", "usage": "Supporting text" },
    "labelLarge": { "ios": "caption (12pt)", "android": "12sp medium", "usage": "Timestamps, metadata" },
    "labelMedium": { "ios": "caption2 (11pt)", "android": "11sp regular", "usage": "Smallest labels" }
  },
  "spacing": {
    "xs": { "ios": "4pt", "android": "4dp", "usage": "Tight grouping within component" },
    "sm": { "ios": "8pt", "android": "8dp", "usage": "Between related components" },
    "md": { "ios": "12pt", "android": "12dp", "usage": "Inside cards and form fields" },
    "lg": { "ios": "16pt", "android": "16dp", "usage": "Card-level padding, list items" },
    "xl": { "ios": "20pt", "android": "20dp", "usage": "Between major sections" },
    "xxl": { "ios": "24pt", "android": "24dp", "usage": "Top-level screen sections" }
  },
  "cornerRadius": {
    "large": { "ios": "16pt", "android": "16dp", "usage": "Large cards, bottom sheets" },
    "medium": { "ios": "12pt", "android": "12dp", "usage": "Medium cards, dialogs" },
    "form": { "ios": "10pt", "android": "10dp", "usage": "Form fields, text inputs" },
    "small": { "ios": "8pt", "android": "8dp", "usage": "Chips, tags" },
    "capsule": { "ios": "Capsule", "android": "50% radius", "usage": "Pill buttons, badges" }
  },
  "icons": {
    "_note": "All icons below map to custom 24x24 SVGs (1.5px stroke, outline, currentColor). 'custom' is the canonical asset name. 'ios_legacy' and 'android_legacy' show what each platform currently uses before migration.",

    "golf_swing":       { "custom": "golf-swing",       "ios_legacy": "figure.golf",          "android_legacy": "Icons.Filled.SmartToy",    "usage": "Caddie tab, Ask Caddie button, recommendations, execution plan" },
    "golf_bag":         { "custom": "golf-bag",          "ios_legacy": "bag.fill",             "android_legacy": "Icons.Default.GolfCourse", "usage": "Your Bag nav link, bag reminder" },
    "golf_flag":        { "custom": "golf-flag",         "ios_legacy": "flag.fill",            "android_legacy": "Icons.Default.Flag",        "usage": "Hole par indicator, tee selector, course map overlays" },
    "golf_tee":         { "custom": "golf-tee",          "ios_legacy": null,                   "android_legacy": null,                        "usage": "Tee Box Preference nav link and screen" },
    "golf_ball":        { "custom": "golf-ball",         "ios_legacy": null,                   "android_legacy": "Icons.Default.SportsGolf",  "usage": "Swing Info nav link" },
    "target":           { "custom": "target",            "ios_legacy": "target",               "android_legacy": null,                        "usage": "Recommended target in shot advice" },
    "wind":             { "custom": "wind",              "ios_legacy": "wind",                 "android_legacy": null,                        "usage": "Wind condition indicator on course map" },
    "slope_uphill":     { "custom": "slope-uphill",      "ios_legacy": null,                   "android_legacy": null,                        "usage": "Uphill slope indicator in shot conditions" },
    "slope_downhill":   { "custom": "slope-downhill",    "ios_legacy": null,                   "android_legacy": null,                        "usage": "Downhill slope indicator in shot conditions" },
    "hazard_warning":   { "custom": "hazard-warning",    "ios_legacy": "exclamationmark.triangle(.fill)", "android_legacy": null,             "usage": "Error/warning states, hazard alerts" },
    "distance_marker":  { "custom": "distance-marker",   "ios_legacy": "ruler",                "android_legacy": null,                        "usage": "Yardage/distance measurement on course map" },

    "fairway":          { "custom": "fairway",           "ios_legacy": null,                   "android_legacy": null,                        "usage": "Lie picker — fairway" },
    "rough":            { "custom": "rough",             "ios_legacy": null,                   "android_legacy": null,                        "usage": "Lie picker — rough" },
    "bunker":           { "custom": "bunker",            "ios_legacy": null,                   "android_legacy": null,                        "usage": "Lie picker — bunker/sand" },
    "green":            { "custom": "green",             "ios_legacy": null,                   "android_legacy": null,                        "usage": "Lie picker — on the green" },
    "water":            { "custom": "water",             "ios_legacy": null,                   "android_legacy": null,                        "usage": "Lie picker — water hazard" },
    "tree_line":        { "custom": "tree-line",         "ios_legacy": null,                   "android_legacy": null,                        "usage": "Hazard context — tree-lined" },

    "microphone":       { "custom": "microphone",        "ios_legacy": "mic",                  "android_legacy": "Icons.Default.Mic",         "usage": "Voice input active" },
    "microphone_off":   { "custom": "microphone-off",    "ios_legacy": null,                   "android_legacy": "Icons.Default.MicOff",      "usage": "Voice input inactive" },
    "camera":           { "custom": "camera",            "ios_legacy": "camera.circle.fill",   "android_legacy": "Icons.Default.Photo",       "usage": "Photo capture in shot input" },
    "send":             { "custom": "send",              "ios_legacy": null,                   "android_legacy": "Icons.AutoMirrored.Filled.Send", "usage": "Send follow-up question" },
    "clipboard":        { "custom": "clipboard",         "ios_legacy": "doc.on.clipboard",     "android_legacy": null,                        "usage": "Paste API key" },
    "trash":            { "custom": "trash",             "ios_legacy": "trash",                "android_legacy": "Icons.Default.Delete",      "usage": "Delete/remove actions" },
    "edit_pencil":      { "custom": "edit-pencil",       "ios_legacy": null,                   "android_legacy": null,                        "usage": "Edit club distances" },

    "home":             { "custom": "home",              "ios_legacy": null,                   "android_legacy": null,                        "usage": "Reserved for future use" },
    "map_pin":          { "custom": "map-pin",           "ios_legacy": "mappin.circle",        "android_legacy": "Icons.Default.LocationOn",  "usage": "Course location indicator" },
    "course_map":       { "custom": "course-map",        "ios_legacy": "map",                  "android_legacy": "Icons.Filled.GolfCourse",   "usage": "Course tab icon" },
    "history_clock":    { "custom": "history-clock",     "ios_legacy": "clock.arrow.trianglehead.counterclockwise.rotate.90", "android_legacy": "Icons.Filled.History", "usage": "History tab, empty state" },
    "profile_user":     { "custom": "profile-user",      "ios_legacy": "person.circle",        "android_legacy": "Icons.Filled.Person",       "usage": "Profile tab icon" },
    "settings_gear":    { "custom": "settings-gear",     "ios_legacy": "gearshape.2",          "android_legacy": "Icons.Default.Settings",    "usage": "API Settings nav link" },
    "search":           { "custom": "search",            "ios_legacy": null,                   "android_legacy": "Icons.Default.Search",      "usage": "Course search" },
    "star_filled":      { "custom": "star-filled",       "ios_legacy": "star.fill",            "android_legacy": "Icons.Filled.Star",         "usage": "Favorite course (filled)" },
    "star_outline":     { "custom": "star-outline",      "ios_legacy": "star",                 "android_legacy": "Icons.Filled.StarBorder",   "usage": "Favorite course (outline)" },

    "chevron_right":    { "custom": "chevron-right",     "ios_legacy": "chevron.right",        "android_legacy": "Icons.AutoMirrored.Filled.KeyboardArrowRight", "usage": "Disclosure indicator" },
    "chevron_down":     { "custom": "chevron-down",      "ios_legacy": "chevron.up.chevron.down", "android_legacy": "Icons.Default.ArrowDropDown", "usage": "Dropdown/expand controls" },
    "close_x":          { "custom": "close-x",           "ios_legacy": "xmark / xmark.circle.fill", "android_legacy": "Icons.Default.Close",  "usage": "Dismiss/close actions" },
    "back_arrow":       { "custom": "back-arrow",        "ios_legacy": "(system-managed)",     "android_legacy": "Icons.AutoMirrored.Filled.ArrowBack", "usage": "Back navigation (Android only — iOS uses system back)" },
    "plus":             { "custom": "plus",              "ios_legacy": "plus.circle",          "android_legacy": "Icons.Default.Add",         "usage": "Add club, add item" },

    "checkmark":        { "custom": "checkmark",         "ios_legacy": "checkmark / checkmark.circle(.fill)", "android_legacy": "Icons.Default.Check", "usage": "Selection confirmation" },
    "info_circle":      { "custom": "info-circle",       "ios_legacy": "info.circle(.fill)",   "android_legacy": null,                        "usage": "Information/detail buttons" },
    "speaker_on":       { "custom": "speaker-on",        "ios_legacy": null,                   "android_legacy": "Icons.Default.VolumeUp",    "usage": "Text-to-speech active" },
    "speaker_off":      { "custom": "speaker-off",       "ios_legacy": null,                   "android_legacy": "Icons.Default.StopCircle / Stop", "usage": "Text-to-speech stopped" },

    "crown_pro":        { "custom": "crown-pro",         "ios_legacy": "crown",                "android_legacy": null,                        "usage": "Pro tier badge" },
    "ai_brain":         { "custom": "ai-brain",          "ios_legacy": "brain / brain.head.profile", "android_legacy": null,                  "usage": "AI model indicator, analysis insights" }
  }
}
